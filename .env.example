# Copy this file to .env and fill in the secrets. .env is git-ignored.

# 1. Talk to @BotFather on Telegram, send /newbot, copy the token:
TELEGRAM_BOT_TOKEN=
# 2. Send any message to your bot, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy the chat id.
#    Multiple recipients: comma-separated, e.g. 123456789,987654321
#    (each person must message the bot once first)
TELEGRAM_CHAT_ID=

# Optional overrides (defaults shown):
#DAILY_RUN_AT=12:05
#RETRY_ATTEMPTS=15
#RETRY_DELAY_MINUTES=10
